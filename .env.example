# =========================================================================
# GLOBAL ENVIRONMENT SETTINGS
# =========================================================================
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh

# =========================================================================
# BACKEND (API) CONFIGURATION
# =========================================================================
APP_NAME="Identify Voice API"
APP_VERSION="1.0.0"
BE_PORT=3000
BACKEND_URL="http://localhost:3000"

# Security & Auth
JWT_ACCESS_SECRET=your_super_secret_access_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10

# Storage & Uploads
STORAGE_DRIVER=local
STORAGE_ROOT_DIR=./storage
STORAGE_PUBLIC_DIR=public
STORAGE_PRIVATE_DIR=private
STORAGE_TEMP_DIR=temp
STORAGE_CDN_URL="http://localhost:3000/cdn"
STORAGE_MAX_SIZE=52428800
STORAGE_ALLOWED_MIMES=audio/wav,audio/vnd.wave,audio/wave,audio/x-wav,audio/mpeg,audio/mp3,audio/mp4,video/mp4,audio/x-m4a,audio/flac,audio/x-flac,audio/ogg

# =========================================================================
# DATABASE (POSTGRESQL) CONFIGURATION
# =========================================================================
DB_HOST=localhost
DB_PORT=5442
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=voice_db
DB_SCHEMA=public

# Standardized DATABASE_URL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}

# Docker Database Config (Keep in sync with variables above)
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_DB=${DB_NAME}
DEV_DB_PORT=5442
PROD_DB_PORT=5442

# =========================================================================
# CACHE (REDIS) CONFIGURATION
# =========================================================================
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=password_1233
REDIS_DB_PORT=6382

# Standardized REDIS_URL
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# =========================================================================
# EMAIL (SMTP) CONFIGURATION
# =========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Your Base <no-reply@ecommerce.com>"
EMAIL_FROM="${APP_NAME} <${SMTP_USER}>"
EMAIL_TEMPLATES_PATH=src/module/email/templates

# =========================================================================
# THIRD-PARTY SERVICES & OAUTH
# =========================================================================

# Google OAuth
GOOGLE_CLIENT_ID="GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"

# AI Service (Voice Processing)
AI_SERVICE_URL=http://localhost:1122
AI_SERVICE_TIMEOUT=30000
AUDIO_NORMALIZE_TIMEOUT_MS=15000

# =========================================================================
# MONITORING & LOGGING
# =========================================================================
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
PROMETHEUS_ENABLED=false
METRICS_PORT=9090
HEALTH_ENDPOINTS_ENABLED=false

# =========================================================================
# NETWORK & CORS
# =========================================================================
CORS_ORIGINS="http://localhost:5173,http://localhost:5177,http://localhost:3001,http://localhost:3002,http://localhost:3003"
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# =========================================================================
# COOKIE
# =========================================================================
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_MAX_AGE=604800000
COOKIE_PATH=/
