COMPOSE_PROJECT_NAME=identify-voice

# Images
BACKEND_IMAGE=ghcr.io/your-org/identify-voice-backend
CLIENT_IMAGE=ghcr.io/your-org/identify-voice-client
IMAGE_TAG=latest

# Runtime
NODE_ENV=production
TZ=Asia/Ho_Chi_Minh
CLIENT_PORT=8080
PORT=3000
CLIENT_API_BASE_URL=/api/v1

# App
APP_NAME=Identify Voice API
APP_VERSION=1.0.0
BACKEND_URL=https://your-domain.example

# Auth
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_SECRET=change-me
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10

# Storage
STORAGE_DRIVER=local
STORAGE_ROOT_DIR=./storage
STORAGE_PUBLIC_DIR=public
STORAGE_PRIVATE_DIR=private
STORAGE_TEMP_DIR=temp
STORAGE_CDN_URL=https://your-domain.example/cdn
STORAGE_MAX_SIZE=52428800
STORAGE_ALLOWED_MIMES=audio/wav,audio/vnd.wave,audio/wave,audio/x-wav,audio/mpeg,audio/mp3,audio/mp4,video/mp4,audio/x-m4a,audio/flac,audio/x-flac,audio/ogg

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=voice_db
DB_SCHEMA=public

# Redis
REDIS_PASSWORD=change-me

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=no-reply@example.com
EMAIL_FROM=Identify Voice <no-reply@example.com>
EMAIL_TEMPLATES_PATH=src/module/email/templates

# External services
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://your-domain.example/api/v1/auth/google/callback


AI_SERVICE_URL=http://host.docker.internal:1122
AI_SERVICE_TIMEOUT=30000

# Logging / monitoring
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
PROMETHEUS_ENABLED=false
METRICS_PORT=9090
HEALTH_ENDPOINTS_ENABLED=false

# Network / security
CORS_ORIGINS=https://your-domain.example
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
COOKIE_DOMAIN=your-domain.example
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_MAX_AGE=604800000
COOKIE_PATH=/


# Email configuration for production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=test@example.com
SMTP_PASS=test-password
EMAIL_FROM=Identify Voice <test@example.com>
EMAIL_TEMPLATES_PATH=src/module/email/templates
