// ============================================================
// Voice Identify Service — Prisma Schema
// ORM: Prisma | Database: PostgreSQL
// ============================================================
// MIGRATION NOTE (Manual):
// The following indexes must be created manually after migration,
// as Prisma does not support partial indexes natively:
//
//   DROP INDEX IF EXISTS "voice_records_user_id_key";
//   DROP INDEX IF EXISTS "voice_records_voice_id_key";
//
//   CREATE UNIQUE INDEX voice_records_user_id_active_unique
//   ON voice_records (user_id)
//   WHERE is_active = TRUE;
//
// This enforces that each user can have at most ONE active voice record.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

/// Role của tài khoản operator trong hệ thống
enum Role {
  ADMIN
  OPERATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

/// Trạng thái của job cập nhật embedding giọng nói (Async)
enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

/// Mục đích của file audio được upload
enum AudioPurpose {
  ENROLL
  IDENTIFY
  UPDATE_VOICE
}

enum UserSource {
  SYSTEM
  AI_IMPORTED
}

enum UserGender {
  MALE
  FEMALE
  OTHER
}

enum TranslationMode {
  TRANSLATE
  SUMMARIZE
}

// ============================================================
// MODELS
// ============================================================

/// Tài khoản đăng nhập hệ thống — dành cho operator/admin
model auth_accounts {
  id            String     @id @default(uuid()) @db.Uuid
  /// Email tài khoản, phải là duy nhất trong hệ thống
  email         String     @unique
  /// Tên đăng nhập, phải là duy nhất trong hệ thống
  username      String?    @unique
  /// Mật khẩu đã hash bằng bcrypt, không bao giờ lưu plain text
  password      String
  /// Phân quyền tài khoản
  role          Role       @default(ADMIN)
  /// Danh sách permission động cho operator/admin, lưu dưới dạng JSON array
  permissions   Json?      @db.JsonB
  /// Refresh token đã hash (nullable)
  refresh_token String?
  /// Trạng thái tài khoản
  status        UserStatus @default(ACTIVE)

  /// Các phiên nhận dạng được thực hiện bởi account này
  identify_sessions   identify_sessions[]
  /// Các file audio được upload bởi account này
  uploaded_files      audio_files[]
  /// Lịch sử dịch được thực hiện bởi account này
  translation_records translation_records[]

  voice_update_logs voice_update_logs[]

  @@map("auth_accounts")
}

/// Thông tin người được định danh bởi hệ thống AI
model users {
  id                     String  @id @default(uuid()) @db.Uuid
  /// Họ và tên đầy đủ
  name                   String
  /// Số CCCD / CMND (nullable)
  citizen_identification String?
  /// Số điện thoại (nullable)
  phone_number           String?
  /// Quê quán (nullable)
  hometown               String?
  /// Nghề nghiệp (nullable)
  job                    String?
  /// Số hộ chiếu (nullable)
  passport               String?
  /// Tiền án tiền sự dạng JSON string: [{case: string, year: number}]
  criminal_record        Json?   @db.JsonB

  /// Tuổi người địng danh (nullable)
  age Int?

  /// Giới tính người đing danh (nullable)
  gender UserGender?

  /// Nguồn gốc tạo user
  source UserSource @default(SYSTEM)

  /// Url file audio for user enroll
  audio_url String?

  /// Các phiên bản hồ sơ giọng nói liên kết với người dùng này
  voice_records     voice_records[]
  /// Danh sách job cập nhật giọng nói liên quan
  update_voice_jobs update_voice_jobs[]

  /// Index tìm kiếm theo tên, CCCD, số điện thoại
  @@index([name])
  @@index([citizen_identification])
  @@index([phone_number])
  @@map("users")
}

// AI chỉ “đề xuất danh tính”. Không bao giờ được phép đụng vào users.
model ai_identities_cache {
  /// Voice ID do AI trả về (Qdrant point id)
  voice_id String @id

  name                   String?
  citizen_identification String?
  phone_number           String?
  hometown               String?
  job                    String?
  passport               String?
  criminal_record        Json?   @db.JsonB

  raw           Json     @db.JsonB
  first_seen_at DateTime @default(now())

  @@map("ai_identities_cache")
}

/// Quản lý metadata của các file audio lưu trên local filesystem
model audio_files {
  id           String       @id @default(uuid()) @db.Uuid
  /// Đường dẫn thực thể trên disk (vd: /uploads/voices/uuid.wav)
  file_path    String       @unique
  /// Tên file gốc người dùng upload
  file_name    String
  /// MIME Type (audio/wav, audio/mpeg, v.v.)
  mime_type    String
  /// Kích thước file (bytes)
  size_bytes   Int
  /// Thời lượng audio tính bằng giây (điền sau khi AI Service xử lý)
  duration_sec Float?
  /// Mục đích upload file này
  purpose      AudioPurpose
  /// ID của operator đã upload file
  uploaded_by  String       @db.Uuid

  /// Thời điểm upload
  created_at DateTime  @default(now())
  /// Soft-delete — đánh dấu khi file đã bị xóa khỏi disk
  deleted_at DateTime?

  operator auth_accounts @relation(fields: [uploaded_by], references: [id], onDelete: Restrict)

  /// Các quan hệ tham chiếu tới file này
  voice_records     voice_records[]
  identify_sessions identify_sessions[]
  voice_update_logs voice_update_logs[]

  @@index([purpose])
  @@index([uploaded_by])
  @@index([deleted_at])
  @@map("audio_files")
}

/// Hồ sơ giọng nói — hỗ trợ versioning, mỗi user có 1 bản active
model voice_records {
  id            String   @id @default(uuid()) @db.Uuid
  /// Khóa ngoại tới users.id
  user_id       String   @db.Uuid
  /// Snap shot for user info
  user_name     String?
  user_email    String?
  /// Point ID trong Qdrant do AI Service cấp
  voice_id      String
  /// Khóa ngoại tới audio_files.id — mẫu audio dùng để trích xuất embedding này
  audio_file_id String   @db.Uuid
  /// Trạng thái hoạt động của giọng nói
  is_active     Boolean  @default(true)
  /// Thời điểm tạo bản ghi
  created_at    DateTime @default(now())

  user              users               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  audio_file        audio_files         @relation(fields: [audio_file_id], references: [id], onDelete: Restrict)
  voice_update_logs voice_update_logs[]

  @@index([user_id])
  @@index([user_id, is_active])
  @@index([voice_id])
  @@map("voice_records")
}

/// Lịch sử các phiên nhận dạng giọng nói
model identify_sessions {
  id            String   @id @default(uuid()) @db.Uuid
  /// FK tới auth_accounts.id — operator thực hiện
  user_id       String   @db.Uuid
  /// FK tới audio_files.id — file audio input dùng để nhận dạng
  audio_file_id String   @db.Uuid
  /// Kết quả AI dạng JSON: [{voice_id, score, name, ...}]
  results       Json     @db.JsonB
  /// Thời điểm thực hiện
  identified_at DateTime @default(now())

  operator   auth_accounts @relation(fields: [user_id], references: [id], onDelete: Restrict)
  audio_file audio_files   @relation(fields: [audio_file_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([identified_at])
  @@index([user_id, identified_at])
  @@map("identify_sessions")
}

/// Hàng đợi các job cập nhật embedding (async processing)
model update_voice_jobs {
  id             String    @id @default(uuid()) @db.Uuid
  /// voice_id cần cập nhật embedding
  voice_id       String
  /// FK tới users.id — người sở hữu giọng nói
  user_id        String    @db.Uuid
  /// Mảng ID các audio_files mới: ["uuid", "uuid"]
  audio_file_ids Json      @db.JsonB
  /// Trạng thái job
  status         JobStatus @default(PENDING)
  /// Tiến độ 0-100
  progress       Int       @default(0)
  /// Thông báo lỗi nếu thất bại
  error_msg      String?
  /// Thời điểm tạo job
  created_at     DateTime  @default(now())
  /// Thời điểm cập nhật gần nhất
  updated_at     DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([voice_id])
  @@index([status])
  @@index([user_id])
  @@index([voice_id, status])
  @@map("update_voice_jobs")
}

/// Lịch sử cập nhật model giọng nói (khi admin quyết định enrich thêm data)
model voice_update_logs {
  id              String   @id @default(uuid()) @db.Uuid
  voice_record_id String   @db.Uuid
  voice_id        String
  audio_file_id   String   @db.Uuid
  updated_by      String   @db.Uuid
  created_at      DateTime @default(now())

  audio_file   audio_files   @relation(fields: [audio_file_id], references: [id], onDelete: Restrict)
  operator     auth_accounts @relation(fields: [updated_by], references: [id], onDelete: Restrict)
  voice_record voice_records @relation(fields: [voice_record_id], references: [id], onDelete: Cascade)

  @@index([voice_record_id])
  @@index([voice_id])
  @@index([audio_file_id])
  @@map("voice_update_logs")
}

/// Lịch sử dịch văn bản, chỉ admin được truy xuất để thống kê và đối soát
model translation_records {
  id              String          @id @default(uuid()) @db.Uuid
  user_id         String          @db.Uuid
  source_text     String
  translated_text String
  source_lang     String?
  target_lang     String
  mode            TranslationMode @default(TRANSLATE)
  created_at      DateTime        @default(now())

  operator auth_accounts @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([created_at])
  @@index([target_lang])
  @@index([mode])
  @@map("translation_records")
}
